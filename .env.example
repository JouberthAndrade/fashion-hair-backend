# ── Application ─────────────────────────────────────────
NODE_ENV=development
PORT=3333

# ── Database ─────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/fashion_hair"

# ── Redis ─────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT ───────────────────────────────────────────────────
# Generate strong secrets: openssl rand -hex 32
JWT_ACCESS_SECRET="your-super-secret-access-key-min-32-characters"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-characters"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:5173"

# ── Security ─────────────────────────────────────────────
BCRYPT_ROUNDS=12

# Enable only when running behind a trusted reverse proxy (nginx, Cloudflare).
# When "false", request.ip is taken from the socket (no forwarded-header spoof).
TRUST_PROXY=false

# ── Public booking ───────────────────────────────────────
TZ=America/Sao_Paulo
PUBLIC_BOOKING_MAX_DAYS=30
PRIVACY_POLICY_VERSION=1.0
# Optional: UUID of a system user for price audit (defaults to collaboratorId)
# PUBLIC_BOOKING_ACTOR_ID=
